{
  "name": "discord-music-bot-pro",
  "version": "1.0.0",
  "description": "Professional Discord music bot with slash commands, search by artist/song name, queueing, and yt-dlp powered playback.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "register": "node src/register-commands.js",
    "check": "node -c src/index.js && node -c src/register-commands.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.19.3",
    "ffmpeg-static": "^5.2.0",
    "prism-media": "^1.3.5"
  }
}
